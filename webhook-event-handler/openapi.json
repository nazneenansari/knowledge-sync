      },
      "UnauthorizedError": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error",
            "description": "Machine-readable error code. Always `UNAUTHORIZED` for 401 responses.",
            "examples": [
              "UNAUTHORIZED"
            ]
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable description of the authentication failure.",
            "examples": [
              "Missing or invalid HMAC signature.",
              "X-Timestamp header is absent or outside the ±5 min tolerance.",
              "X-Signature header is missing."
            ]
          }
        },
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "title": "UnauthorizedError",
        "description": "Returned on HTTP 401 when authentication credentials are missing or the HMAC signature cannot be verified."
      },
      "ForbiddenError": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error",
            "description": "Machine-readable error code. Always `FORBIDDEN` for 403 responses.",
            "examples": [
              "FORBIDDEN"
            ]
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable description of why the request was denied.",
            "examples": [
              "Tenant acme-corp is not authorised to publish articles.",
              "appId egain-cms-v3 does not have permission to call this endpoint.",
              "Insufficient permissions to access the Dead Letter Queue."
            ]
          }
        },
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "title": "ForbiddenError",
        "description": "Returned on HTTP 403 when the caller is authenticated but not permitted to perform the requested operation."
      },
      "InternalServerError": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error",
            "description": "Machine-readable error code. Always `INTERNAL_SERVER_ERROR` for 500 responses.",
            "examples": [
              "INTERNAL_SERVER_ERROR"
            ]
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable description of the server-side failure.",
            "examples": [
              "An unexpected error occurred. Please try again later.",
              "Queue service is temporarily unavailable.",
              "Failed to persist event to the database."
            ]
          },
          "details": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Details",
            "description": "Optional diagnostic detail. Omitted in production to avoid leaking internal state.",
            "examples": [
              null
            ]
          }
        },
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "title": "InternalServerError",
        "description": "Returned on HTTP 500 when an unexpected server-side error prevents the request from completing."
      },
