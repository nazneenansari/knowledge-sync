      "ErrorResponse": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error",
            "description": "Machine-readable error code.",
            "examples": [
              "INVALID_PAYLOAD"
            ]
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable error description.",
            "examples": [
              "Payload must include data.articleId."
            ]
          },
          "details": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Details",
            "description": "Optional list of field-level validation errors.",
            "examples": [
              [
                "data.articleId: field required",
                "data.urlName: field required"
              ]
            ]
          }
        },
        "type": "object",
        "required": [
          "error",
          "message"
