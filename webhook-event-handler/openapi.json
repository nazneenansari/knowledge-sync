  },
  "components": {
    "schemas": {
      "AcceptedResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "accepted",
            "examples": [
              "accepted"
            ]
          },
          "eventId": {
            "type": "string",
            "format": "uuid",
            "title": "Eventid",
            "description": "Assigned UUID for status polling.",
            "examples": [
              "3fa85f64-5717-4562-b3fc-2c963f66afa6"
            ]
          },
          "message": {
            "type": "string",
            "title": "Message",
            "examples": [
              "Article publish event queued for processing."
            ]
          }
        },
        "type": "object",
        "required": [
          "eventId",
          "message"
        ],
        "title": "AcceptedResponse",
        "description": "Returned immediately (HTTP 202) for every inbound webhook."
      },
      "ArticleData": {
        "properties": {
          "articleId": {
            "type": "string",
            "title": "Articleid",
            "description": "Unique article identifier in eGain.",
            "examples": [
              "ARTICLE-1001"
            ]
          },
          "title": {
            "type": "string",
            "maxLength": 255,
            "title": "Title",
            "description": "Article title — maps to Salesforce Knowledge `Title` field.",
            "examples": [
              "How to reset your password"
            ]
          },
          "content": {
            "type": "string",
            "title": "Content",
            "description": "Full HTML article body. Maps to Salesforce `ArticleBody`.",
            "examples": [
              "<p>Step 1: Click <b>Forgot Password</b>...</p>"
            ]
          },
          "language": {
            "type": "string",
            "title": "Language",
            "description": "BCP-47 language tag. Maps to Salesforce `Language`.",
            "default": "en-US",
            "examples": [
              "en-US",
              "fr-FR",
              "de-DE"
            ]
          },
          "version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Version",
            "description": "Article version string stored in custom field `eGain__Source_Article_Version__c`.",
            "examples": [
              "2.0"
            ]
          },
          "categories": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Categories",
            "description": "eGain category names. Joined with ';' into Salesforce `eGain__Categories__c`.",
            "examples": [
              [
                "Account Management",
                "Security"
              ]
            ]
          }
        },
        "type": "object",
        "required": [
          "articleId",
          "title",
          "urlName",
          "content"
        ],
        "title": "ArticleData",
        "description": "Knowledge article payload from eGain CMS."
      },
      "ArticlePublishedWebhook": {
        "properties": {
          "webhookId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Webhookid",
            "description": "Unique delivery ID assigned by eGain. Use for idempotency checks.",
            "examples": [
              "wh_01HZK8M3N2PQRS"
            ]
          },
          "event": {
            "type": "string",
            "title": "Event",
            "description": "Must be exactly `article.published`.",
            "examples": [
              "article.published"
            ]
          },
          "tenantId": {
            "type": "string",
            "title": "Tenantid",
            "description": "eGain tenant identifier. Required for all webhook calls.",
            "examples": [
              "acme-corp"
            ]
          },
          "appId": {
            "type": "string",
            "title": "Appid",
            "description": "Identifier of the application triggering this webhook.",
            "examples": [
              "egain"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp",
            "description": "ISO-8601 event time in UTC.",
            "examples": [
              "2024-06-01T12:00:00Z"
            ]
          },
          "data": {
            "$ref": "#/components/schemas/ArticleData"
          }
        },
        "type": "object",
        "required": [
          "event",
          "tenantId",
          "appId",
          "timestamp",
          "data"
        ],
        "title": "ArticlePublishedWebhook",
        "description": "Webhook envelope sent by eGain when a knowledge article is published or updated.\nTriggers a push to **Salesforce Knowledge** (`Knowledge__kav` sObject)."
      },
      "ArticleViewData": {
        "properties": {
          "articleId": {
            "type": "string",
            "title": "Articleid",
            "description": "eGain article identifier.",
            "examples": [
              "ARTICLE-1001"
            ]
          },
          "articleVersion": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Articleversion",
            "description": "Version of the article viewed. Null if version tracking is off.",
            "examples": [
              "2.0"
            ]
          },
          "sessionId": {
            "type": "string",
            "title": "Sessionid",
            "description": "Browser / portal session identifier.",
            "examples": [
              "sess_abc123def456"
            ]
          },
          "userId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Userid",
            "description": "Authenticated user ID. Null for anonymous (self-service) views.",
            "examples": [
              "usr_xyz789"
            ]
          },
          "channel": {
            "$ref": "#/components/schemas/Channel",
            "description": "Surface where the article was viewed.",
            "default": "web",
            "examples": [
              "web"
            ]
          },
          "durationSeconds": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Durationseconds",
            "description": "Time in seconds the user spent on the article page.",
            "examples": [
              45
            ]
          },
          "helpful": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Helpful",
            "description": "User's helpfulness rating. `true` = helpful, `false` = not helpful, `null` = not yet rated.",
            "examples": [
              true
            ]
          },
          "searchQuery": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Searchquery",
            "description": "Search term that led the user to this article, if any.",
            "examples": [
              "reset password"
            ]
          },
          "caseId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Caseid",
            "description": "Salesforce Case ID if the article was viewed in a case context.",
            "examples": [
              "5003000000ABC123AAA"
            ]
          },
          "userAgent": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Useragent",
            "description": "Browser user-agent string.",
            "examples": [
              "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)"
            ]
          },
          "locale": {
            "type": "string",
            "title": "Locale",
            "description": "User locale (BCP-47).",
            "default": "en-US",
            "examples": [
              "en-US"
            ]
          },
          "deviceType": {
            "$ref": "#/components/schemas/DeviceType",
            "description": "Device category derived from user-agent.",
            "default": "unknown",
            "examples": [
              "desktop"
            ]
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp",
            "description": "Client-side event time. Falls back to server receipt time if absent.",
            "examples": [
              "2024-06-01T17:00:00Z"
            ]
          }
        },
        "type": "object",
        "required": [
          "articleId",
          "sessionId"
        ],
        "title": "ArticleViewData",
        "description": "Article view analytics event from the eGain portal."
      },
      "ArticleViewedWebhook": {
        "properties": {
          "webhookId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Webhookid",
            "examples": [
              "wh_03HZK0N5O4RSTU"
            ]
          },
          "event": {
            "type": "string",
            "title": "Event",
            "description": "Must be exactly `article.viewed`.",
            "examples": [
              "article.viewed"
            ]
          },
          "tenantId": {
            "type": "string",
            "title": "Tenantid",
            "description": "eGain tenant identifier. Required for all webhook calls.",
            "examples": [
              "acme-corp"
            ]
          },
          "appId": {
            "type": "string",
            "title": "Appid",
            "description": "Identifier of the application triggering this webhook.",
            "examples": [
              "egain-portal-v2"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp",
            "examples": [
              "2024-06-01T17:00:00Z"
            ]
          },
          "data": {
            "$ref": "#/components/schemas/ArticleViewData"
          }
        },
        "type": "object",
        "required": [
          "event",
          "tenantId",
          "appId",
          "timestamp",
          "data"
        ],
        "title": "ArticleViewedWebhook",
        "description": "Webhook envelope sent by eGain on every article page view.\nHigh-throughput endpoint — expect bursts of hundreds of events per second.\nEvents are streamed to the eGain Analytics API (or Kafka/Kinesis in production)."
      },
      "CaseClosedWebhook": {
        "properties": {
          "event": {
            "type": "string",
            "title": "Event",
            "description": "Must be exactly `case.closed`.",
            "examples": [
              "case.closed"
            ]
          },
          "tenantId": {
            "type": "string",
            "title": "Tenantid",
            "description": "eGain tenant identifier. Required for all webhook calls.",
            "examples": [
              "acme-corp"
            ]
          },
          "appId": {
            "type": "string",
            "title": "Appid",
            "description": "Identifier of the application triggering this webhook.",
            "examples": [
              "salesforce-service-cloud"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp",
            "description": "ISO-8601 event time in UTC.",
            "examples": [
              "2024-06-01T15:00:00Z"
            ]
          },
          "data": {
            "$ref": "#/components/schemas/CaseData"
          }
        },
        "type": "object",
        "required": [
          "event",
          "tenantId",
          "appId",
          "timestamp",
          "data"
        ],
        "title": "CaseClosedWebhook",
        "description": "Webhook envelope from Salesforce (Outbound Message or Platform Event)\nwhen a support case is closed. Triggers content-gap analysis in eGain."
      },
      "CaseData": {
        "properties": {
          "caseId": {
            "type": "string",
            "title": "Caseid",
            "description": "Salesforce Case record ID (15 or 18-char Salesforce ID).",
            "examples": [
              "5003000000ABC123AAA"
            ]
          },
          "caseNumber": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Casenumber",
            "description": "Human-readable case number shown in Salesforce UI.",
            "examples": [
              "00001234"
            ]
          },
          "subject": {
            "type": "string",
            "maxLength": 255,
            "title": "Subject",
            "description": "Case subject line.",
            "examples": [
              "Cannot log into portal"
            ]
          },
          "description": {
            "type": "string",
            "title": "Description",
            "description": "Full case description / customer problem statement.",
            "examples": [
              "User says password reset email not arriving."
            ]
          },
          "resolution": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Resolution",
            "description": "Agent resolution notes. Null = no resolution recorded.",
            "examples": [
              "Sent user the password reset knowledge article."
            ]
          },
          "category": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category",
            "description": "Salesforce case category / record type.",
            "default": "Uncategorised",
            "examples": [
              "Account Management"
            ]
          },
          "priority": {
            "$ref": "#/components/schemas/Priority",
            "description": "Salesforce case priority.",
            "default": "Medium",
            "examples": [
              "Medium"
            ]
          },
          "articleIds": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Articleids",
            "description": "eGain article IDs **suggested** to the agent during the case.",
            "examples": [
              [
                "ARTICLE-1001",
                "ARTICLE-1005"
              ]
            ]
          },
          "viewedArticleIds": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Viewedarticleids",
            "description": "eGain article IDs the agent actually **opened/read**.",
            "examples": [
              [
                "ARTICLE-1001"
              ]
            ]
          }
        },
        "type": "object",
        "required": [
          "caseId",
          "subject",
          "description"
        ],
        "title": "CaseData",
        "description": "Salesforce case payload delivered on case closure."
      },
